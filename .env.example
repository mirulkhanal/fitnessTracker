# wrAuth API (required for release builds)
# Use HTTPS in production when possible.
EXPO_PUBLIC_WRAUTH_API_URL=https://your-wrauth-host.example.com
EXPO_PUBLIC_WRAUTH_APP_KEY=app_your_key_here

# Allow HTTP API URLs on Android (auto-enabled when EXPO_PUBLIC_WRAUTH_API_URL starts with http://)
# EXPO_PUBLIC_ALLOW_CLEARTEXT=true
